root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 170

[*.{java,kt,groovy,gradle.kts}]
indent_size = 4

[*.{js,ts,jsx,tsx,css,scss,less}]
indent_size = 4

[*.{yml,yaml,json}]
indent_size = 4

[*.{xml,html}]
indent_size = 4

[*.{md}]
indent_size = 4
